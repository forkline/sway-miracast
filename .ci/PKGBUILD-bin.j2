# Maintainer: Pando85 <pando855@gmail.com>
pkgname=swaybeam-bin
pkgver={{ pkg_ver | default(version.stdout) }}
pkgrel=1
pkgdesc="Miracast source implementation for wlroots-based compositors written in Rust (binary)"
arch=('x86_64')
url="https://github.com/forkline/swaybeam"
license=('MIT')
provides=('swaybeam')
conflicts=('swaybeam')

source_x86_64=("swaybeam-${pkgver}.tar.gz::https://github.com/forkline/swaybeam/releases/download/v${pkgver}/swaybeam-x86_64-unknown-linux-gnu.tar.gz")
sha256sums_x86_64=('{{ sha256sums.stdout }}')

package() {
    install -Dm755 "swaybeam" "${pkgdir}/usr/bin/swaybeam"
}
