    }

    #[test]
    fn test_net_error_display() {
        let error = NetError::CommandFailed("test command failed".to_string());
        let display = format!("{}", error);
        assert!(display.contains("test command failed"));

        let error = NetError::NetworkManagerError("network error".to_string());
        let display = format!("{}", error);
        assert!(display.contains("network error"));

        let error = NetError::ConnectionTimeout;
        let display = format!("{}", error);
        assert!(display.contains("Connection timeout"));

        let error = NetError::DeviceNotFound("device not found".to_string());
        let display = format!("{}", error);
        assert!(display.contains("device not found"));

        let io_error = std::io::Error::new(std::io::ErrorKind::NotFound, "io test");
        let error = NetError::IoError(io_error);
        let display = format!("{}", error);
        assert!(display.contains("io test"));

        let error = NetError::ParseError("parse error".to_string());
        let display = format!("{}", error);
        assert!(display.contains("parse error"));
    }

    #[test]
    fn test_net_error_from_io() {
        let io_error =
            std::io::Error::new(std::io::ErrorKind::PermissionDenied, "permission denied");
        let net_error: NetError = io_error.into();
        assert!(matches!(net_error, NetError::IoError(_)));
    }

    #[test]
    fn test_mac_address_validation() {
        // In our implementation, MAC validation is done in parse_discovered_devices
        let manager = P2pManager::new(P2pConfig {
            interface_name: "wlan0".to_string(),
            group_name: "test_group".to_string(),
        })
        .unwrap();

        let valid_output = "NAME         DEVICE     MAC              BARS
ValidDevice  p2p-valid  AA:BB:CC:DD:EE:FF  ****
";

        let result = manager.parse_discovered_devices(valid_output);
        assert!(result.is_ok());
        let sinks = result.unwrap();
        assert_eq!(sinks.len(), 1); // Should be accepted

        let invalid_output = "NAME         DEVICE       MAC             BARS
InvalidDevice  p2p-invalid  BADMACADDR      ***
";

        let result = manager.parse_discovered_devices(invalid_output);
        assert!(result.is_ok());
        let sinks = result.unwrap();
        assert_eq!(sinks.len(), 0); // Should be rejected
    }
}

// Integration test that can optionally run with real nmcli
#[cfg(all(test, feature = "integration"))]
mod integration_tests {
    use super::*;

    #[test]
    fn test_real_nmcli_commands() {
        let runner = RealCommandRunner;

        // Test nmcli device status - should run without error if nmcli is available
        let output = runner.run("nmcli", &["device", "status"]);

        match output {
            Ok(_) => println!("Real nmcli command executed successfully"),
            Err(e) => {
                // We expect this to fail in CI or systems without nmcli,
                // so just document that and exit gracefully
                eprintln!("Integration test failed with real command: {}", e);
                return; // Gracefully skip if nmcli not available
            }
        }
    }
}
