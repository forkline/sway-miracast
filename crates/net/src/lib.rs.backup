    #[test]
    fn test_discover_sinks_parse_error() {
        let mut mock_runner = MockCommandRunner::new();

        // First rescan
        mock_runner.add_response(
            "nmcli",
            &["device", "wifi", "rescan"],
            Ok(CommandOutput {
                stdout: vec![],
                stderr: vec![],
                status: true,
            }),
        );

        // Then list command with non-utf8 output
        mock_runner.add_response(
            "nmcli",
            &["device", "wifi", "list", "--fields", "NAME,DEVICE,MAC,BARS"],
            Ok(CommandOutput {
                stdout: vec![0x80, 0x81, 0x82], // Invalid UTF-8
                stderr: vec![],
                status: true,
            }),
        );

        let config = P2pConfig {
            interface_name: "wlan0".to_string(),
            group_name: "test_group".to_string(),
        };

        let manager = P2pManager::new_with_command_runner(config, mock_runner).unwrap();
        let result = manager.discover_sinks(Duration::from_secs(10));

        assert!(matches!(result.unwrap_err(), NetError::ParseError(_)));
    }

    #[test]
    fn test_connect_success() {
        let mut mock_runner = MockCommandRunner::new();

        // First check if already connected
        mock_runner.add_response(
            "nmcli",
            &["device", "status"],
            Ok(CommandOutput {
                stdout: b"wlan0 p2p-wlan0 disconnected \neth0 ethernet --"
                    .as_bytes()
                    .to_vec(),
                stderr: vec![],
                status: true,
            }),
        );

        // Connect to device
        mock_runner.add_response(
            "nmcli",
            &["device", "wifi", "connect", "TestDevice"],
            Ok(CommandOutput {
                stdout: b"Device 'p2p-wlan0-0' successfully activated with '12345678-1234-1234-1234-123456789abc'.\n".as_bytes().to_vec(),
                stderr: vec![],
                status: true,
            }),
        );

        // Show to get IP address
        mock_runner.add_response(
            "nmcli",
            &["device", "show", "wlan0"],
            Ok(CommandOutput {
                stdout: b"GENERAL.DEVICE:                         p2p-wlan0-0
GENERAL.TYPE:                           wifi-p2p
GENERAL.STATE:                          connected
IP4.ADDRESS[1]:                         192.168.1.100/24
"
                .as_bytes()
                .to_vec(),
                stderr: vec![],
                status: true,
            }),
        );

        let config = P2pConfig {
            interface_name: "wlan0".to_string(),
            group_name: "test_group".to_string(),
        };

        let manager = P2pManager::new_with_command_runner(config, mock_runner).unwrap();
        let sink = Sink {
            name: "TestDevice".to_string(),
            address: "AA:BB:CC:DD:EE:FF".to_string(),
            ip_address: None,
        };

        let result = manager.connect(&sink);
        assert!(result.is_ok());

        let connection = result.unwrap();
        assert_eq!(connection.get_sink().name, "TestDevice");
        assert_eq!(
            connection.get_sink().ip_address,
            Some("192.168.1.100".to_string())
        );
    }

    #[test]
    fn test_connect_already_connected() {
        let mut mock_runner = MockCommandRunner::new();

        // First check if already connected - yes it is
        mock_runner.add_response(
            "nmcli",
            &["device", "status"],
            Ok(CommandOutput {
                stdout: b"wlan0 p2p-wlan0 connected WW:XX:YY:ZZ:00:11 \neth0 ethernet --"
                    .as_bytes()
                    .to_vec(),
                stderr: vec![],
                status: true,
            }),
        );

        let config = P2pConfig {
            interface_name: "wlan0".to_string(),
            group_name: "test_group".to_string(),
        };

        let manager = P2pManager::new_with_command_runner(config, mock_runner).unwrap();
        let sink = Sink {
            name: "TestDevice".to_string(),
            address: "WW:XX:YY:ZZ:00:11".to_string(),
            ip_address: None,
        };

        let result = manager.connect(&sink);
        assert!(matches!(
            result.unwrap_err(),
            NetError::NetworkManagerError(_)
        ));
    }

    #[test]
    fn test_connect_failure() {
        let mut mock_runner = MockCommandRunner::new();

        // First check if already connected
        mock_runner.add_response(
            "nmcli",
            &["device", "status"],
            Ok(CommandOutput {
                stdout: b"wlan0 p2p-wlan0 disconnected \neth0 ethernet --"
                    .as_bytes()
                    .to_vec(),
                stderr: vec![],
                status: true,
            }),
        );

        // Connect to device - will fail
        mock_runner.add_response(
            "nmcli",
            &["device", "wifi", "connect", "TestDevice"],
            Ok(CommandOutput {
                stdout: vec![],
                stderr: b"Error: Failed to activate connection".as_bytes().to_vec(),
                status: false,
            }),
        );

        let config = P2pConfig {
            interface_name: "wlan0".to_string(),
            group_name: "test_group".to_string(),
        };

        let manager = P2pManager::new_with_command_runner(config, mock_runner).unwrap();
        let sink = Sink {
            name: "TestDevice".to_string(),
            address: "AA:BB:CC:DD:EE:FF".to_string(),
            ip_address: None,
        };

        let result = manager.connect(&sink);
        assert!(result.is_err());
        assert!(matches!(result.unwrap_err(), NetError::CommandFailed(_)));
    }

